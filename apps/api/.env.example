# ─── Server Configuration ──────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database Configuration (Drizzle ORM & Postgres) ─
# Lưu ý: Host nên khớp với dịch vụ trong docker-compose (ví dụ: localhost ở local dev, postgres trong docker network)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=agentx_user
DATABASE_PASSWORD=agentx_secure_password
DATABASE_NAME=agentx_db
# URL đầy đủ sử dụng cho một số công cụ hoặc script di trú (migration)
DATABASE_URL=postgresql://agentx_user:agentx_secure_password@localhost:5432/agentx_db

# ─── Redis Cache & Session Configuration ────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT Authentication Secrets ────────────────────────
# Phải tạo các chuỗi khóa dài và an toàn trong môi trường production
JWT_ACCESS_SECRET=dev_access_secret_key_should_be_long_and_secure_at_least_32_characters
JWT_REFRESH_SECRET=dev_refresh_secret_key_should_be_long_and_secure_at_least_32_characters

# ─── Credential Encryption (AES-256-GCM) ────────────────
# Dùng để mã hóa API keys, OAuth tokens của các tích hợp MCP Server
# Bắt buộc phải là chuỗi có độ dài đúng 32 ký tự
ENCRYPTION_KEY=dev_encryption_key_32_chars_long!

# ─── Default Admin Account Seeding ──────────────────────
# Tài khoản quản trị hệ thống sẽ được tự động khởi tạo khi chạy lần đầu
ADMIN_DEFAULT_EMAIL=admin@agentx.local
ADMIN_DEFAULT_PASSWORD=Admin@123456

# ─── LLM Tier Configuration ────────────────────────────
# Lựa chọn LLM mặc định cho từng phân nhóm xử lý (Tiers)
# Bạn có thể dùng 'anthropic', 'openai', hoặc 'local'

# Ví dụ dùng Local Model (như Ollama)
# LLM_FAST_PROVIDER=local
# LLM_FAST_MODEL=llama3.1:8b-instruct-q8_0

# Hoặc dùng API ngoài:
LLM_FAST_PROVIDER=anthropic
LLM_FAST_MODEL=claude-4-haiku-20250414

LLM_SMART_PROVIDER=anthropic
LLM_SMART_MODEL=claude-4-sonnet-20250514

LLM_VISION_PROVIDER=openai
LLM_VISION_MODEL=gpt-4o

# ─── LLM API Keys (Điền ít nhất một nhà cung cấp) ───────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=

# ─── Local AI Configuration (Ollama) ───────────────────
LOCAL_AI_BASE_URL=http://localhost:11434/v1
LOCAL_AI_API_KEY=ollama


# ─── API Security ──────────────────────────────────────
# CORS_ORIGINS phân tách bằng dấu phẩy
CORS_ORIGINS=http://localhost:3000
